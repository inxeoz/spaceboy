{{- $pages := where .Site.RegularPages "Type" "in" .Site.Params.mainSections -}}
[
{{- range $i, $p := $pages -}}
{{- if $i }},{{ end }}
{
  "title":      {{ $p.Title | jsonify }},
  "url":        {{ $p.RelPermalink | jsonify }},
  "date":       {{ $p.Date.Format "2006-01-02" | jsonify }},
  "tags":       {{ $p.Params.tags | default slice | jsonify }},
  "categories": {{ $p.Params.categories | default slice | jsonify }},
  "summary":    {{ $p.Summary | plainify | truncate 200 | jsonify }},
  "imageAlts":  [
    {{- $alts := slice -}}
    {{- range findRE `!\[[^\]]+\]` $p.RawContent -}}
      {{- $alt := . | replaceRE `^!\[` "" | replaceRE `\]$` "" -}}
      {{- if $alt -}}{{- $alts = $alts | append $alt -}}{{- end -}}
    {{- end -}}
    {{- range $j, $a := $alts -}}{{- if $j }},{{ end }}{{ $a | jsonify }}{{- end -}}
  ]
}
{{- end }}
]
